"[{\"AllowMultiple\":false,\"EndLine\":486,\"ReplacementContent\":\"const getPointX = (pt: any): number => {\\n  if (!pt) return 0;\\n  if (Array.isArray(pt)) return Number(pt[0] ?? 0);\\n  if (typeof pt === 'object') return Number(pt.x !== undefined ? pt.x : (pt[0] ?? 0));\\n  return 0;\\n};\\n\\nconst getPointY = (pt: any): number => {\\n  if (!pt) return 0;\\n  if (Array.isArray(pt)) return Number(pt[1] ?? 0);\\n  if (typeof pt === 'object') return Number(pt.y !== undefined ? pt.y : (pt[1] ?? 0));\\n  return 0;\\n};\\n\\nconst mapX = (x: number, xRange: [number, number], width: number = 600): number => {\\n  const [minX, maxX] = xRange;\\n  const range = maxX - minX;\\n  const safeRange = range === 0 ? 1 : range;\\n  return 50 + ((x - minX) / safeRange) * (width - 100);\\n};\\n\\nconst mapY = (y: number, yRange: [number, number], height: number = 400): number => {\\n  const [minY, maxY] = yRange;\\n  const range = maxY - minY;\\n  const safeRange = range === 0 ? 1 : range;\\n  return (height - 50) - ((y - minY) / safeRange) * (height - 100);\\n};\\n\\nconst getBounds = (data: any): { xRange: [number, number]; yRange: [number, number] } => {\\n  const xRange: [number, number] = data.xRange || [-10, 10];\\n  const yRange: [number, number] = data.yRange || [-10, 10];\\n  return { xRange, yRange };\\n};\\n\\nconst getCoordinateBounds = (points: any[]): { xRange: [number, number]; yRange: [number, number] } => {\\n  let minX = -2;\\n  let maxX = 10;\\n  let minY = -2;\\n  let maxY = 10;\\n  if (points && points.length > 0) {\\n    const xs = points.map(p => getPointX(p));\\n    const ys = points.map(p => getPointY(p));\\n    minX = Math.min(...xs, 0) - 2;\\n    maxX = Math.max(...xs, 0) + 2;\\n    minY = Math.min(...ys, 0) - 2;\\n    maxY = Math.max(...ys, 0) + 2;\\n  }\\n  return { xRange: [minX, maxX], yRange: [minY, maxY] };\\n};\",\"StartLine\":457,\"TargetContent\":\"const mapX = (x: number, xRange: [number, number], width: number = 600): number => {\\n  const [m