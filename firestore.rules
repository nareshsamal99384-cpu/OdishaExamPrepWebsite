rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, hasFullAccess, purchasedSeries, createdAt
    //
    // Collection: exams
    // Fields: id, name, description, icon
    //
    // Collection: testSeries
    // Fields: id, examId, title, description, price, durationDays, testIds
    //
    // Collection: mockTests
    // Fields: id, seriesId, title, durationMinutes, totalMarks
    //
    // Collection: questions
    // Fields: id, examId, topic, difficulty, questionText, options, correctAnswerIndex, explanation
    //
    // Collection: attempts
    // Fields: id, userId, testId, score, accuracy, answers, completedAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         ((request.auth.token.email == "nareshsamal99384@gmail.com" || request.auth.token.email == "odishaexamprep365@gmail.com") && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return data.uid is string && 
             data.email is string && 
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
        ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
        ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /exams/{examId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testSeries/{seriesId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mockTests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /attempts/{attemptId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
