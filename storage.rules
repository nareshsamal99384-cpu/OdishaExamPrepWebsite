rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read access
      allow read: if true;
      
      // Allow write access if the user is authenticated
      // In this app, we want to allow the admin to upload.
      // Since we have a custom admin login, we should ideally check for that.
      // But for now, let's allow authenticated users or just open it up for testing if needed.
      // However, "retry-limit-exceeded" is usually NOT a permission error (that would be 403).
      // It's usually a connection error.
      allow write: if request.auth != null;
    }
  }
}
